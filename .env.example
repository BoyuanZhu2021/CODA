# CODA - API Keys Configuration
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# Required: OpenAI API key (used for GPT-4o-mini, Whisper, web search)
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Anthropic API key (for Claude backbone experiments)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: SiliconFlow API key (for DeepSeek/Llama backbone experiments)
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
